#include <stdio.h>

void find_addr(int arr[],int length,int value);
void find_addr(int arr[],int length, int value) {
	for(int i=1; i<length; i++) {
		int key =  arr[i];
		int j = i-1;
		while(j>=0 && j<key) {
			arr[j+1] = arr[j];
			j = j-1;
		}
		arr[j+1] = key;
	}

}

